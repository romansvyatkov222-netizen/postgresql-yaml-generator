# Пример переменных окружения для MC-DB Forge
# Используйте либо DB_URL, либо отдельные DB_* переменные ниже.

DB_PASSWORD=my_secret_password
DB_URL=postgres://postgres:postgres@localhost:5432/mcdb_test
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=mcdb_test
DB_SSL=false
DB_SSL_MODE=require
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SSL_CA_PATH=certs/ca.pem
DB_SSL_CERT_PATH=certs/client-cert.pem
DB_SSL_KEY_PATH=certs/client-key.pem

